# Copy this file to .env and fill in your keys.

SERPAPI_KEY=your_serpapi_key_here

# Apollo is optional. If blank, enrichment is skipped and firmographic columns
# (revenue/employees/industry/founded) are left blank — SerpApi still returns
# real companies, job titles, platforms and hiring-intent counts.
APOLLO_KEY=

# Force full synthetic demo (both services), no API calls. Leave blank normally.
# MOCK_MODE=true

# Password gate for public deployments (Render etc.). If set, the UI prompts for
# it and the API rejects requests without it. Leave blank for local use.
APP_PASSWORD=

# SerpApi geo/locale
SERPAPI_GL=us
SERPAPI_HL=en
SERPAPI_LOCATION=United States

# Pages per query (10 jobs/page). 2 = up to ~20 postings/query.
MAX_PAGES_PER_QUERY=2

# Where generated spreadsheets are written
OUTPUT_DIR=/tmp/serp_leads
